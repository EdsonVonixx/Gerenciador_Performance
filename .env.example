# Reservado para a proxima fase com Supabase.
# Nunca use service_role ou secret key no frontend.

# Use `local` para prototipo sem banco e `supabase` para producao conectada.
VITE_VPC_DATA_MODE=local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Os usuarios do Supabase Auth devem seguir o padrao:
# almoxarifado@vpc.vonixx.local, recebimento@vpc.vonixx.local, estoque@vpc.vonixx.local,
# secos@vpc.vonixx.local, quimicas@vpc.vonixx.local e gestao@vpc.vonixx.local.
VITE_VPC_AUTH_EMAIL_SUFFIX=vpc.vonixx.local
